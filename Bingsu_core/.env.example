# API Configuration
# ว่าง = ใช้ origin ปัจจุบัน (เหมาะกับ LAN: เครื่องอื่นเข้า http://YOUR_IP:8080 ได้)
# หรือตั้งเป็น http://YOUR_IP:8000 ถ้าเรียก API โดยตรง
REACT_APP_API_BASE_URL=
REACT_APP_API_TIMEOUT=30000

# Environment
REACT_APP_ENV=development

# Security
REACT_APP_ENABLE_HTTPS_ONLY=true

# Note: Never commit .env file with real values to git
# Copy this file to .env and update with your actual values
