# ============================================
# Bingsu / bb Backend - Environment Variables
# ============================================
# คัดลอกไปเป็น .env หรือ .env.local แล้วเติมค่าจริง (อย่าใส่ key ในไฟล์นี้แล้ว commit)
# Docker Compose โหลด: Backend/.env และ Backend/.env.local

# ============================================
# Server Configuration
# ============================================
ENV=development
HOST=0.0.0.0
PORT=5052

# ============================================
# Frontend / API URLs
# ============================================
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8083
# URL หลักของระบบ (สำหรับ LINE Webhook / Ngrok) — เติมเมื่อ deploy หรือใช้ LINE
PUBLIC_BASE_URL=
CORS_ORIGINS=http://localhost:3000,http://localhost:8083,http://127.0.0.1:3000

# ============================================
# Database (bb Docker: postgres ที่ 5436)
# ============================================
# จาก host: localhost:5436 | ใน Docker: postgres:5432 (compose override)
DATABASE_URL=postgresql://postgres:postgres@localhost:5436/ask_the_manual?schema=public

# ============================================
# Qdrant (bb Docker: 6336)
# ============================================
QDRANT_URL=http://localhost:6336
QDRANT_API_KEY=
QDRANT_COLLECTION=documents
QDRANT_DISTANCE=Cosine
QDRANT_TOP_K=6

# ============================================
# Redis (bb Docker: 6382)
# ============================================
REDIS_URL=redis://localhost:6382
RATE_LIMIT_REDIS_PREFIX=rate
UPLOAD_QUEUE_MODE=memory

# ============================================
# Auth / Session
# ============================================
SESSION_TTL_DAYS=30
REQUIRE_EMAIL_VERIFICATION=true
ALLOW_SIGNUP_AUTO_APPROVE=false

# ============================================
# Rate Limiting / โควต้าแชท
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
FREE_DAILY_TOKEN_LIMIT=500000

# ============================================
# Embeddings — เติม API key ใน .env จริง
# ============================================
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_MS=10000

# ============================================
# RAG
# ============================================
RAG_TIMEOUT_MS=2000
RAG_QUERY_VARIANT_LIMIT=4

# ============================================
# OCR / PDF — เติม TYPHOON_OCR_API_KEY ใน .env จริงถ้าใช้ Typhoon
# ============================================
PDF_PROVIDER=pdfplumber
# ลองดึง text layer (pdfplumber → pdf.js) ก่อนเรียก Typhoon — ปิดด้วย false ถ้าอยากบังคับ OCR เสมอ
PDF_TRY_TEXT_BEFORE_TYPHOON_OCR=true
# ลองสคริปต์ scripts/extract_pdf_plumber.py ก่อน pdf.js (แนะนำ true เมื่อมี Python + pdfplumber)
PDF_TRY_PLUMBER_FIRST=true
OCR_ALWAYS_FOR_PDF=false
OCR_PROVIDER=typhoon
OCR_ENABLED=true
TYPHOON_OCR_API_KEY=
TYPHOON_OCR_API_URL=https://api.opentyphoon.ai/v1/ocr
OCR_LANG=th
OCR_MAX_PAGES=30
# ถ้าดึง text ได้รวมทั้งไฟล์น้อยกว่านี้ (หลังตัด whitespace) ถือว่าเป็นสแกน → ใช้ Typhoon
OCR_MIN_TEXT_CHARS=400

# ============================================
# Chat / LLM — เติม OPENAI_API_KEY หรือ GEMINI_API_KEY ใน .env จริง
# ============================================
GATEWAY_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_DEPLOYMENT_RETRY_ATTEMPTS=2
OPENAI_DEPLOYMENT_RETRY_BASE_DELAY_MS=2500
GEMINI_API_KEY=
CHAT_TIMEOUT_MS=30000
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=4000
# OCR → LLM (ปุ่ม "จัดเรียงด้วย AI" / clean ข้อความ) — โมเดลเริ่มต้นแนะนำ gpt-4o-mini ผ่าน gateway เดียวกับแชท
OCR_LLM_PROVIDER=openai
OCR_LLM_MODEL=gpt-4o-mini
# OCR_LLM_BASE_URL=   # ว่าง = ใช้ GATEWAY_BASE_URL
# OCR_LLM_API_KEY=    # ว่าง = ใช้ OPENAI_API_KEY

# ============================================
# File Upload
# ============================================
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,text/plain,text/markdown
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md
MAX_UPLOAD_FILE_MB=200
MAX_UPLOAD_PART_MB=20
STORE_RAW_FILES=false
FILE_STORAGE_PROVIDER=local

# ============================================
# Text / Chunking
# ============================================
TEXT_CHUNK_SIZE=1800
TEXT_CHUNK_OVERLAP=100
PDF_SPLIT_PAGE_THRESHOLD=400
PDF_PAGES_PER_CHUNK=50

# ============================================
# Cache
# ============================================
CACHE_TTL_SECONDS=30

# ============================================
# Ngrok — เติมใน .env จริงเมื่อใช้ ngrok (LINE Webhook ฯลฯ)
# ============================================
# NGROK_AUTHTOKEN=

# ============================================
# LINE Messaging API — เติมใน .env จริงเมื่อเชื่อม LINE OA
# ============================================
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_DEFAULT_BOT_ID=

# ============================================
# Optional: S3, Email, etc.
# ============================================
# S3_ENDPOINT= S3_REGION= S3_ACCESS_KEY_ID= S3_SECRET_ACCESS_KEY= S3_BUCKET=
# SMTP_SERVER=smtp.yourmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=aisupport@ntplc.co.th
# SMTP_PASSWORD=your-password
# SMTP_FROM=BingSu <aisupport@ntplc.co.th>
# SUPPORT_APPROVAL_EMAIL=supportadmin@yourdomain.com
# SUPPORT_ADMIN_URL=http://localhost:3014/pending-users
# LOG_LEVEL=INFO
# NODE_ENV=development
