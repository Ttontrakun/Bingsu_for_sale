  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.697.0",
    "@google/genai": "^1.29.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.8",
    "pdfjs-dist": "^4.10.38",
    "redis": "^4.7.0",
    "undici": "^7.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
