{
  "name": "askaa-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:legacy": "node --watch server/index.js",
    "dev:fastapi": "python -m uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 5051",
    "start:server": "node server/index.js",
    "start:web": "node server/index.js",
    "start:worker": "node server/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:admins": "node server/scripts/seed-admins.js",
    "seed:pending-demo": "node server/scripts/seed-pending-demo-user.js",
    "seed:demo-applicants": "node server/scripts/seed-demo-applicants.js",
    "seed:admins:docker": "docker compose --profile app exec legacy node server/scripts/seed-admins.js",
    "seed:help-bot": "node server/scripts/seed-help-bot.js",
    "reindex:documents": "node server/scripts/reindex-documents.js",
    "security:rotation-checklist": "node server/scripts/security-rotation-checklist.js",
